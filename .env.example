# ==================== APP ====================
PORT=3008
NODE_ENV=development

# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vchat
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# Prisma connection string (build từ các biến trên)
DATABASE_URL="postgresql://postgres:your_strong_password_here@localhost:5432/vchat?schema=public"

# ==================== JWT ====================
# Tạo key mới bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_KEY=your_access_key_here
JWT_REFRESH_KEY=your_refresh_key_here
JWT_ACCESS_EXPIRE=30m
JWT_REFRESH_EXPIRE=7d

# ==================== EMAIL (Gmail App Password) ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Support App <no-reply@example.com>"

# ==================== REDIS ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== RABBITMQ ====================
RABBITMQ_URL=amqp://guest:guest@localhost

# ==================== GOOGLE OAUTH ====================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000

# ==================== APP HOST ====================
APP_HOST=localhost
